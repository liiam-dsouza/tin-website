---
import Wrapper from "./Wrapper.astro"
import SectionTitle from "./SectionTitle.astro"

const SCHEDULE = [
    { time: '3:00 PM', title: 'Doors Open', desc: 'Check-in and early networking with industry.', category: 'Social' },
    { time: '4:00 PM', title: 'Event Opening', desc: 'Welcome to Tech Industry Night 2026!', category: 'Talk' },
    { time: '4:10 PM', title: 'Keynote Presentation 1', desc: 'TBC. Stay tuned!', category: 'Talk' },
    { time: '4:30 PM', title: 'Keynote Presentation 2', desc: 'TBC. Stay tuned!', category: 'Talk' },
    { time: '4:50 PM', title: 'Panel Q&A', desc: 'Panel Q&A with attending industry', category: 'Q&A' },
    { time: '5:50 PM', title: 'Networking & Food', desc: 'Chat with other attending industry and enjoy some food and beverages.', category: 'Networking' },
    { time: '8:00 PM', title: 'Event Conclusion', desc: 'Thank you for coming!', category: 'Talk' },
]
---

<Wrapper id="schedule">
    <SectionTitle title="Event Schedule" subtitle="What's Happening" description="Plan your night to make the most of every opportunity." />

	<div class="relative border-l-2 border-pink-200 ml-4 md:ml-0">
		{
			SCHEDULE.map(item => (
				<div class="relative pl-8 pb-12 group">
					<div class="absolute -left-2.5 top-0 w-4 h-4 rounded-full bg-pink-500 ring-4 ring-white shadow-lg group-hover:scale-125 transition-transform" />
					<div class="flex flex-col md:flex-row md:items-center gap-2 mb-2">
						<span class="text-pink-500 font-bold text-lg">{item.time}</span>
						<span class="hidden md:block text-gray-300 mx-2">•</span>
						<span class="px-3 py-1 rounded-full bg-purple-50 text-purple-500 text-xs font-bold uppercase tracking-widest w-fit">
							{item.category}
						</span>
					</div>
					<h3 class="text-2xl font-bold mb-2">{item.title}</h3>
					<p class="text-gray-600 leading-relaxed">{item.desc}</p>
				</div>
			))
		}
	</div>
</Wrapper>
