---
interface Props {
    title: string
    subtitle: string
    description: string
}

const { title, subtitle, description } = Astro.props
---

<div class="flex flex-col items-center mx-auto text-center">
    <span class="text-orange-500 font-bold tracking-widest uppercase text-sm mb-4 block">{ subtitle }</span>
    <h2 class="font-black text-5xl sm:text-6xl">{ title }</h2>
    <p class="text-md sm:text-lg max-w-2xl mx-auto my-4">
        { description }
    </p>
</div>
